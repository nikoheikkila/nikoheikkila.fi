{
	"$schema": "https://docs.renovatebot.com/renovate-schema.json",
	"extends": [
		"config:recommended",
		":automergeBranch",
		":automergeMinor",
		":automergeRequireAllStatusChecks",
		":combinePatchMinorReleases",
		":configMigration",
		":dependencyDashboard",
		":maintainLockFilesDisabled"
	],
	"enabledManagers": [
		"bun",
		"github-actions",
		"terraform",
		"custom.regex"
	],
	"schedule": [
		"every weekend"
	],
	"customManagers": [
		{
			"customType": "regex",
			"managerFilePatterns": [
				"/^\\.github/workflows/.*\\.ya?ml$/"
			],
			"matchStrings": [
				"WRANGLER_VERSION:\\s*[\"']?(?<currentValue>\\d+\\.\\d+\\.\\d+)[\"']?"
			],
			"depNameTemplate": "wrangler",
			"datasourceTemplate": "npm"
		},
		{
			"customType": "regex",
			"managerFilePatterns": [
				"/^\\.github/workflows/.+\\.ya?ml$/"
			],
			"matchStrings": [
				"image: mcr\\.microsoft\\.com/playwright:v(?<currentValue>[\\d.]+)-noble"
			],
			"depNameTemplate": "@playwright/test",
			"datasourceTemplate": "npm"
		}
	],
	"packageRules": [
		{
			"extends": [
				"monorepo:gatsby"
			],
			"matchUpdateTypes": [
				"digest",
				"patch",
				"minor",
				"major"
			],
			"groupName": "Gatsby packages"
		},
		{
			"matchPackageNames": [
				"wrangler"
			],
			"groupName": "Wrangler"
		},
		{
			"matchPackageNames": [
				"@playwright/test"
			],
			"groupName": "Playwright"
		}
	]
}